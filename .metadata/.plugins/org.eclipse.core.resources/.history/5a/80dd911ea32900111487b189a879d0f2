package com.codearena.code.repository;

import com.codearena.code.entity.Leaderboard;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;
import java.util.List;

@Repository
public interface LeaderboardRepository extends JpaRepository<Leaderboard, Long> {
    List<Leaderboard> findByRoomIdOrderByScoreDesc(String roomId);
    Leaderboard findByRoomIdAndPlayerName(String roomId, String playerName);
}